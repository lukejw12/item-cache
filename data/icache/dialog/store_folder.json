{
  "type": "minecraft:confirmation",
  "title": {"text": "Move to Folder", "color": "gold"},
  "body": [
    {
      "type": "plain_message",
      "contents": {"text": "Item stored! Move it to a folder?", "color": "gray"}
    },
    {
      "type": "plain_message",
      "contents": {"text": "If the folder doesn't exist it will be created.", "color": "dark_gray"}
    }
  ],
  "inputs": [
    {
      "type": "minecraft:text",
      "key": "folder_name",
      "label": "Folder Name (or path like weapons/rare)",
      "max_length": 64,
      "width": 200
    }
  ],
  "yes": {
    "label": {"text": "Move"},
    "action": {
      "type": "dynamic/run_command",
      "template": "function icache:cache/store_to_folder {folder_name:\"$(folder_name)\"}"
    }
  },
  "no": {
    "label": {"text": "Skip"}
  }
}